# Copy this file to .env.local for PWA development (leave blank – Vite proxy handles /api)
VITE_API_URL=

# For an Android APK build, set this to your backend host before running:
#   VITE_API_URL=http://192.168.1.x:3000 npm run build
#   npx cap sync android
# The native WebView calls this URL directly (no Vite proxy).
