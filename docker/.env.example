# ─────────────────────────────────────────────────────────────────────────────
# Tango Platform — Docker environment configuration
# Copy this file to .env in this directory and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# The public-facing URL of your deployment (no trailing slash).
# This is baked into the Android APKs at build time via scripts/build-apks.sh.
# Example: APP_URL=https://tango.example.com
APP_URL=http://localhost

# HTTP port to expose the web portal on (default 80)
HTTP_PORT=80

# ── Database ─────────────────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_PASSWORD=changeme
DB_NAME=transport_saas

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=24h
ACTIVATION_TOKEN_SECRET=change-this-too-in-production
ACTIVATION_TOKEN_EXPIRES_IN=12h

# ── Stripe (optional — leave blank to disable paid tickets) ──────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Firebase / FCM (optional — leave blank to disable push notifications) ────
# Base64-encode your service account JSON:
#   base64 -w 0 service-account.json
FIREBASE_SERVICE_ACCOUNT_BASE64=

# ── Seed admin (only used when running: npm run seed inside the api container) ─
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Admin
